# Smrtayah Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key
# Get free at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Neon PostgreSQL Connection String
# Get free at: https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ChromaDB settings (local by default)
CHROMA_PERSIST_DIR=./chroma_db

# Gemini model settings
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004
